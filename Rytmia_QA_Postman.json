{
  "info": {
    "name": "Rytmia API — QA Seguridad (Hito 1)",
    "_postman_id": "rytmia-qa-hito1",
    "description": "Colección de pruebas de seguridad, tokens y roles para la API de Rytmia. Cubre autenticación, control de acceso por rol y CRUD de usuarios.\n\n**Setup:**\n1. Importa esta colección en Postman.\n2. Crea un entorno (Environment) con la variable `base_url = http://localhost:8000/api`.\n3. Ejecuta las pruebas en orden.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",         "value": "http://localhost:8000/api", "type": "string" },
    { "key": "token_admin",      "value": "", "type": "string" },
    { "key": "token_entrenadora","value": "", "type": "string" },
    { "key": "token_gimnasta",   "value": "", "type": "string" },
    { "key": "usuario_id",       "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "1. AUTENTICACIÓN",
      "item": [
        {
          "name": "1.1 Login correcto — Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Contiene token', () => pm.expect(pm.response.json().token).to.be.a('string'));",
                  "pm.test('Rol = administrador', () => pm.expect(pm.response.json().user.rol).to.eql('administrador'));",
                  "pm.collectionVariables.set('token_admin', pm.response.json().token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dni\": \"00000001A\",\n  \"password\": \"Admin1234\"\n}"
            },
            "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] }
          }
        },
        {
          "name": "1.2 Login correcto — Entrenadora",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Rol = entrenadora', () => pm.expect(pm.response.json().user.rol).to.eql('entrenadora'));",
                  "pm.collectionVariables.set('token_entrenadora', pm.response.json().token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dni\": \"00000002B\",\n  \"password\": \"Laura1234\"\n}"
            },
            "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] }
          }
        },
        {
          "name": "1.3 Login correcto — Gimnasta",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Rol = gimnasta', () => pm.expect(pm.response.json().user.rol).to.eql('gimnasta'));",
                  "pm.collectionVariables.set('token_gimnasta', pm.response.json().token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dni\": \"00000003C\",\n  \"password\": \"Sara1234\"\n}"
            },
            "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] }
          }
        },
        {
          "name": "1.4 Login — DNI incorrecto (debe dar 422)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 422', () => pm.response.to.have.status(422));",
                  "pm.test('Mensaje de error presente', () => pm.expect(pm.response.json().errors).to.have.property('dni'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dni\": \"99999999Z\",\n  \"password\": \"cualquier\"\n}"
            },
            "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] }
          }
        },
        {
          "name": "1.5 Login — Contraseña vacía (debe dar 422)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 422', () => pm.response.to.have.status(422));",
                  "pm.test('Error en campo password', () => pm.expect(pm.response.json().errors).to.have.property('password'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dni\": \"00000001A\",\n  \"password\": \"\"\n}"
            },
            "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] }
          }
        },
        {
          "name": "1.6 Login — DNI con formato inválido (sin letra)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 422 por validación DNI', () => pm.response.to.have.status(422));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dni\": \"12345678\",\n  \"password\": \"Admin1234\"\n}"
            },
            "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] }
          }
        }
      ]
    },
    {
      "name": "2. ME — DATOS PROPIOS",
      "item": [
        {
          "name": "2.1 GET /me — Admin (200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Rol correcto', () => pm.expect(pm.response.json().rol).to.eql('administrador'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_admin}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/me", "host": ["{{base_url}}"], "path": ["me"] }
          }
        },
        {
          "name": "2.2 GET /me — Sin token (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401 sin token', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/me", "host": ["{{base_url}}"], "path": ["me"] }
          }
        },
        {
          "name": "2.3 GET /me — Token manipulado (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401 con token inválido', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer token_falso_manipulado_123" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/me", "host": ["{{base_url}}"], "path": ["me"] }
          }
        }
      ]
    },
    {
      "name": "3. CONTROL DE ROLES",
      "item": [
        {
          "name": "3.1 GET /usuarios — Admin (200 OK)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Devuelve array de datos', () => pm.expect(pm.response.json().data).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_admin}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/usuarios", "host": ["{{base_url}}"], "path": ["usuarios"] }
          }
        },
        {
          "name": "3.2 GET /usuarios — Entrenadora (403 Forbidden)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403 para entrenadora', () => pm.response.to.have.status(403));",
                  "pm.test('Mensaje de rol', () => pm.expect(pm.response.json().message).to.include('permiso'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_entrenadora}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/usuarios", "host": ["{{base_url}}"], "path": ["usuarios"] }
          }
        },
        {
          "name": "3.3 GET /usuarios — Gimnasta (403 Forbidden)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403 para gimnasta', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_gimnasta}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/usuarios", "host": ["{{base_url}}"], "path": ["usuarios"] }
          }
        },
        {
          "name": "3.4 GET /usuarios-por-rol/entrenadora — Entrenadora (200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_entrenadora}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/usuarios-por-rol/entrenadora", "host": ["{{base_url}}"], "path": ["usuarios-por-rol", "entrenadora"] }
          }
        },
        {
          "name": "3.5 GET /usuarios-por-rol/entrenadora — Gimnasta (403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403 para gimnasta', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_gimnasta}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/usuarios-por-rol/entrenadora", "host": ["{{base_url}}"], "path": ["usuarios-por-rol", "entrenadora"] }
          }
        }
      ]
    },
    {
      "name": "4. CRUD USUARIOS (Admin)",
      "item": [
        {
          "name": "4.1 POST /usuarios — Crear entrenadora correcta",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Contiene ID', () => pm.expect(pm.response.json().data.id).to.be.a('number'));",
                  "pm.collectionVariables.set('usuario_id', pm.response.json().data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_admin}}" },
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Marta\",\n  \"apellidos\": \"Ruiz Sánchez\",\n  \"dni\": \"12345678Z\",\n  \"email\": \"marta@rytmia.test\",\n  \"password\": \"Marta1234\",\n  \"rol\": \"entrenadora\",\n  \"telefono\": \"600123456\",\n  \"club_id\": 1,\n  \"titulacion\": \"Nivel I RFEG\",\n  \"anios_experiencia\": 3,\n  \"horas_semanales\": 10,\n  \"estado\": \"activa\",\n  \"biografia\": \"Entrenadora joven con gran pasión por la gimnasia rítmica.\"\n}"
            },
            "url": { "raw": "{{base_url}}/usuarios", "host": ["{{base_url}}"], "path": ["usuarios"] }
          }
        },
        {
          "name": "4.2 POST /usuarios — DNI duplicado (422)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 422 por DNI duplicado', () => pm.response.to.have.status(422));",
                  "pm.test('Error en campo dni', () => pm.expect(pm.response.json().errors).to.have.property('dni'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_admin}}" },
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Otro\",\n  \"apellidos\": \"Usuario\",\n  \"dni\": \"12345678Z\",\n  \"password\": \"Admin1234\",\n  \"rol\": \"administrador\"\n}"
            },
            "url": { "raw": "{{base_url}}/usuarios", "host": ["{{base_url}}"], "path": ["usuarios"] }
          }
        },
        {
          "name": "4.3 GET /usuarios/{id} — Ver entrenadora creada",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Contiene perfil entrenador', () => pm.expect(pm.response.json().data.entrenador).to.exist);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_admin}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/usuarios/{{usuario_id}}", "host": ["{{base_url}}"], "path": ["usuarios", "{{usuario_id}}"] }
          }
        },
        {
          "name": "4.4 PUT /usuarios/{id} — Actualizar datos",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Telefono actualizado', () => pm.expect(pm.response.json().data.telefono).to.eql('699999999'));"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_admin}}" },
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"telefono\": \"699999999\",\n  \"anios_experiencia\": 5\n}"
            },
            "url": { "raw": "{{base_url}}/usuarios/{{usuario_id}}", "host": ["{{base_url}}"], "path": ["usuarios", "{{usuario_id}}"] }
          }
        },
        {
          "name": "4.5 PATCH /usuarios/{id}/toggle-activo",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Estado activo cambiado', () => pm.expect(pm.response.json().data.activo).to.be.a('boolean'));"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_admin}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/usuarios/{{usuario_id}}/toggle-activo", "host": ["{{base_url}}"], "path": ["usuarios", "{{usuario_id}}", "toggle-activo"] }
          }
        },
        {
          "name": "4.6 DELETE /usuarios/{id} — Borrado lógico",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Mensaje de éxito', () => pm.expect(pm.response.json().message).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_admin}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/usuarios/{{usuario_id}}", "host": ["{{base_url}}"], "path": ["usuarios", "{{usuario_id}}"] }
          }
        }
      ]
    },
    {
      "name": "5. LOGOUT",
      "item": [
        {
          "name": "5.1 POST /logout — Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Mensaje de cierre de sesión', () => pm.expect(pm.response.json().message).to.include('cerrada'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_admin}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/logout", "host": ["{{base_url}}"], "path": ["logout"] }
          }
        },
        {
          "name": "5.2 GET /me después de logout (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Token revocado correctamente — 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_admin}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/me", "host": ["{{base_url}}"], "path": ["me"] }
          }
        }
      ]
    }
  ]
}
